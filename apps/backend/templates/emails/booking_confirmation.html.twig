{% extends 'emails/base.html.twig' %}

{% block title %}Booking Confirmation: {{ courseName }}{% endblock %}

{% block extra_head %}
<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "EventReservation",
  "reservationNumber": "{{ uid }}",
  "reservationStatus": "http://schema.org/Confirmed",
  "underName": {
    "@type": "Person",
    "name": "{{ userName }}"
  },
  "reservationFor": {
    "@type": "Event",
    "name": "{{ courseName }}",
    "startDate": "{{ startTime|date('c') }}",
    "endDate": "{{ endTime|date('c') }}",
    "location": {
      "@type": "Place",
      "name": "{{ location }}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ location }}",
        "addressLocality": "München",
        "addressRegion": "Bayern",
        "postalCode": "80331",
        "addressCountry": "DE"
      }
    }
  }
}
</script>
{% endblock %}

{% block body %}
    <h2>Booking Confirmed!</h2>
    <p>Hello <strong>{{ userName }}</strong>,</p>
    <p>Great news! Your booking for <strong>{{ courseName }}</strong> has been confirmed.</p>

    <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; border-left: 4px solid #ffc107; margin-bottom: 30px;">
        <h3 style="margin-top: 0; font-family: 'Barlow Condensed', sans-serif; font-size: 16px;">EVENT DETAILS</h3>
        <p style="margin-bottom: 5px;"><strong>Course:</strong> {{ courseName }}</p>
        <p style="margin-bottom: 5px;"><strong>Date:</strong> {{ startTime|date('d.m.Y') }}</p>
        <p style="margin-bottom: 5px;"><strong>Time:</strong> {{ startTime|date('H:i') }} - {{ endTime|date('H:i') }}</p>
        <p style="margin-bottom: 5px;"><strong>Location:</strong> {{ location }}</p>
    </div>

    <p>We've attached a calendar invite to this email so you can easily add it to your schedule.</p>
    
    <p>See you there!</p>
{% endblock %}
