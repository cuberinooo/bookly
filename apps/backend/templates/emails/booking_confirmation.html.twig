{% extends 'emails/base.html.twig' %}

{% block title %}{{ 'email.booking_confirmation.subject'|trans({'%courseName%': courseName}) }}{% endblock %}

{% block extra_head %}
<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "EventReservation",
  "reservationNumber": "{{ uid }}",
  "reservationStatus": "http://schema.org/Confirmed",
  "underName": {
    "@type": "Person",
    "name": "{{ userName }}"
  },
  "reservationFor": {
    "@type": "Event",
    "name": "{{ courseName }}",
    "startDate": "{{ startTime|date('c') }}",
    "endDate": "{{ endTime|date('c') }}",
    "location": {
      "@type": "Place",
      "name": "{{ location }}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ location }}",
        "addressLocality": "München",
        "addressRegion": "Bayern",
        "postalCode": "80331",
        "addressCountry": "DE"
      }
    }
  }
}
</script>
{% endblock %}

{% block body %}
    <h2>{{ 'email.booking_confirmation.title'|trans }}</h2>
    <p>{{ 'email.booking_confirmation.greeting'|trans({'%userName%': userName})|raw }}</p>
    <p>{{ 'email.booking_confirmation.message'|trans({'%courseName%': courseName})|raw }}</p>

    <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; border-left: 4px solid #ffc107; margin-bottom: 30px;">
        <h3 style="margin-top: 0; font-family: 'Barlow Condensed', sans-serif; font-size: 16px;">{{ 'email.booking_confirmation.details_title'|trans }}</h3>
        <p style="margin-bottom: 5px;"><strong>{{ 'email.booking_confirmation.course'|trans }}</strong> {{ courseName }}</p>
        <p style="margin-bottom: 5px;"><strong>{{ 'email.booking_confirmation.date'|trans }}</strong> {{ startTime|date('d.m.Y') }}</p>
        <p style="margin-bottom: 5px;"><strong>{{ 'email.booking_confirmation.time'|trans }}</strong> {{ startTime|date('H:i') }} - {{ endTime|date('H:i') }}</p>
        <p style="margin-bottom: 5px;"><strong>{{ 'email.booking_confirmation.location'|trans }}</strong> {{ location }}</p>
    </div>

    <p>{{ 'email.booking_confirmation.calendar_invite'|trans }}</p>
    
    <p>{{ 'email.booking_confirmation.closing'|trans }}</p>
{% endblock %}
