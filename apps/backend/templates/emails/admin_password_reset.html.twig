{% extends 'emails/base.html.twig' %}

{% block title %}Password Reset{% endblock %}

{% block body %}
    <h2>Password Reset</h2>
    <p>Hello {{ name }},</p>
    
    <p>An administrator has reset your password for your account at <strong>{{ siteName }}</strong>.</p>
    
    <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; border-left: 4px solid #ffc107; margin-bottom: 30px;">
        <p style="margin: 0;">Your new temporary password is: <strong style="font-family: monospace; font-size: 1.2rem; letter-spacing: 0.1em;">{{ temporaryPassword }}</strong></p>
    </div>

    <p>For your security, you will be required to change this password immediately after logging in.</p>

    <p style="text-align: center; margin: 40px 0;">
        <a href="{{ siteUrl }}/login" class="button">Log In & Update Password</a>
    </p>
    
    <p>If you have any questions, please contact your course administrator.</p>
    
    <p>Best regards,</p>
    <p>The {{ siteName }} Team</p>
{% endblock %}
