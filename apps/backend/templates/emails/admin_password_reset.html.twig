{% extends 'emails/base.html.twig' %}

{% block title %}{{ 'email.admin_password_reset.subject'|trans }}{% endblock %}

{% block body %}
    <h2>{{ 'email.admin_password_reset.title'|trans }}</h2>
    <p>{{ 'email.admin_password_reset.greeting'|trans({'%name%': name}) }}</p>

    <p>{{ 'email.admin_password_reset.message'|trans({'%siteName%': siteName})|raw }}</p>

    <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; border-left: 4px solid #ffc107; margin-bottom: 30px;">
        <p style="margin: 0;">{{ 'email.admin_password_reset.temp_password'|trans }} <strong style="font-family: monospace; font-size: 1.2rem; letter-spacing: 0.1em;">{{ temporaryPassword }}</strong></p>
    </div>

    <p>{{ 'email.admin_password_reset.security_instruction'|trans }}</p>

    <p style="text-align: center; margin: 40px 0;">
        <a href="{{ siteUrl }}/login" class="button">{{ 'email.admin_password_reset.login_and_update'|trans }}</a>
    </p>

    <p>{{ 'email.admin_password_reset.questions'|trans }}</p>

    <p>{{ 'email.admin_password_reset.best_regards'|trans }}</p>
    <p>{{ 'email.admin_password_reset.team'|trans({'%siteName%': siteName}) }}</p>
{% endblock %}
