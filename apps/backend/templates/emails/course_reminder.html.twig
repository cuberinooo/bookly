{% extends 'emails/base.html.twig' %}

{% block title %}Course Reminder: {{ course.title }}{% endblock %}

{% block body %}
    <h2>Your class is starting soon!</h2>
    <p>Hello <strong>{{ course.trainer.name }}</strong>,</p>
    <p>This is a reminder for your upcoming course <strong>{{ course.title }}</strong> starting at <strong>{{ course.startTime|date('H:i') }}</strong> today.</p>

    <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; border-left: 4px solid #ffc107; margin-bottom: 30px;">
        <h3 style="margin-top: 0; font-family: 'Barlow Condensed', sans-serif; font-size: 16px;">SQUAD OVERVIEW</h3>
        <p style="margin-bottom: 10px;">Confirmed Participants: <strong>{{ participants|length }} / {{ course.capacity }}</strong></p>
        
        {% if participants|length > 0 %}
            <ul style="padding-left: 20px; margin: 0;">
                {% for participant in participants %}
                    <li style="margin-bottom: 5px;">{{ participant.name }} ({{ participant.email }})</li>
                {% endfor %}
            </ul>
        {% else %}
            <p style="font-style: italic; color: #94a3b8; margin: 0;">No participants booked yet.</p>
        {% endif %}
    </div>

    <p>Good luck with your training session!</p>
{% endblock %}
