{% extends 'emails/base.html.twig' %}

{% block title %}{{ 'email.course_reminder.subject'|trans({'%courseTitle%': course.title}) }}{% endblock %}

{% block body %}
    <h2>{{ 'email.course_reminder.title'|trans }}</h2>
    <p>{{ 'email.course_reminder.greeting'|trans({'%trainerName%': course.trainer.name})|raw }}</p>
    <p>{{ 'email.course_reminder.message'|trans({'%courseTitle%': course.title, '%startTime%': course.startTime|date('H:i')})|raw }}</p>

    <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; border-left: 4px solid #ffc107; margin-bottom: 30px;">
        <h3 style="margin-top: 0; font-family: 'Barlow Condensed', sans-serif; font-size: 16px;">{{ 'email.course_reminder.squad_overview'|trans }}</h3>
        <p style="margin-bottom: 10px;">{{ 'email.course_reminder.confirmed_participants'|trans({'%count%': participants|length, '%capacity%': course.capacity})|raw }}</p>
        
        {% if participants|length > 0 %}
            <ul style="padding-left: 20px; margin: 0;">
                {% for participant in participants %}
                    <li style="margin-bottom: 5px;">{{ participant.name }} ({{ participant.email }})</li>
                {% endfor %}
            </ul>
        {% else %}
            <p style="font-style: italic; color: #94a3b8; margin: 0;">{{ 'email.course_reminder.no_participants'|trans }}</p>
        {% endif %}
    </div>

    <p>{{ 'email.course_reminder.good_luck'|trans }}</p>
{% endblock %}
