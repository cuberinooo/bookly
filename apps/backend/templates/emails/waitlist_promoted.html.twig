{% extends 'emails/base.html.twig' %}

{% block title %}{{ 'email.waitlist_promoted.subject'|trans({'%courseTitle%': courseTitle}) }}{% endblock %}

{% block body %}
    <h2>{{ 'email.waitlist_promoted.title'|trans }}</h2>
    <p>{{ 'email.waitlist_promoted.greeting'|trans({'%name%': name}) }}</p>
    <p>{{ 'email.waitlist_promoted.message'|trans({'%courseTitle%': courseTitle})|markdown_to_html|raw }}</p>
    
    <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; margin: 20px 0;">
        <p><strong>{{ 'email.waitlist_promoted.course'|trans }}</strong> {{ courseTitle }}</p>
        <p><strong>{{ 'email.waitlist_promoted.time'|trans }}</strong> {{ startTime|date('d.m.Y H:i') }}</p>
    </div>

    <p>{{ 'email.waitlist_promoted.see_you'|trans }}</p>
    <p>{{ 'email.waitlist_promoted.cancel_instruction'|trans }}</p>
    
    <p>{{ 'email.waitlist_promoted.regards'|trans }}<br>{{ 'email.waitlist_promoted.team'|trans({'%siteName%': siteName}) }}</p>
{% endblock %}
